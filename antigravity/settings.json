{
    // --- UI / Minimalism ---
    "workbench.activityBar.location": "hidden",
    "workbench.statusBar.visible": false,
    "breadcrumbs.enabled": false,
    "editor.minimap.enabled": false,
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.vertical": "editor",
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "workbench.editor.tabSizing": "shrink",
    "window.density.editorTabHeight": "compact",
    "explorer.openEditors.visible": 0,
    // --- Native Minimalism (Safe Fallback) ---
    "window.titleBarStyle": "custom",
    "workbench.colorCustomizations": {
        // Blend title bar into the editor background
        "titleBar.activeBackground": "#0d1117", // Matches GitHub Dark Default
        "titleBar.inactiveBackground": "#0d1117",
        "titleBar.border": "#0d1117",
        // remove other borders
        "sideBar.border": "#0d1117",
        "activityBar.border": "#0d1117",
        "tab.border": "#0d1117",
        "editorGroupHeader.tabsBorder": "#0d1117",
        "splitPane.border": "#0d1117"
    },
    // --- Editor Behavior ---
    "window.zoomLevel": 1,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit",
        "source.fixAll": "explicit"
    },
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "editor.fontFamily": "JetBrains Mono, Fira Code, Menlo, monospace",
    "editor.fontLigatures": true,
    "editor.wordWrap": "on",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    // --- Terminal ---
    "terminal.integrated.fontFamily": "MesloLGS NF",
    "terminal.integrated.fontSize": 14,
    "workbench.list.smoothScrolling": true,
    // --- Dart/Flutter (Original settings preserved) ---
    "[dart]": {
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "editor.rulers": [
            80
        ],
        "editor.selectionHighlight": false,
        "editor.suggest.snippetsPreventQuickSuggestions": false,
        "editor.suggestSelection": "first",
        "editor.tabCompletion": "onlySnippets",
        "editor.wordBasedSuggestions": "off"
    },
    "dart.flutterSdkPaths": [
        ".fvm/flutter_sdk"
    ],
    "explorer.fileNesting.patterns": {
        "*.dart": "${capture}.g.dart, ${capture}.freezed.dart"
    },
    "explorer.fileNesting.enabled": true,
    // --- Icons ---
    "workbench.iconTheme": "material-icon-theme",
    // --- Other ---
    "files.autoSave": "afterDelay",
    "git.autofetch": true,
    "git.openRepositoryInParentFolders": "always",
    "gitlens.ai.experimental.provider": "openai",
    "gitlens.ai.experimental.openai.model": "gpt-3.5-turbo",
    "search.exclude": {
        "**/.fvm": true
    },
    "files.watcherExclude": {
        "**/.fvm": true
    },
    "optimizeImages.app": "ImageOptim.app",
    "optimizeImages.searchStartingPath": "assets",
    "todohighlight.exclude": [
        "**/node_modules/**"
    ],
    "todohighlight.include": [
        "**/*.js"
    ],
    "todohighlight.keywords": [
        {
            "text": "todo:",
            "color": "yellow"
        }
    ],
    "python.formatting.provider": "none",
    "redhat.telemetry.enabled": true,
    "github.copilot.editor.enableAutoCompletions": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": false,
        "scminput": false
    },
    "editor.rulers": [],
    "update.showReleaseNotes": false,
    "workbench.remoteIndicator.showExtensionRecommendations": false,
    "cursor.composer.shouldChimeAfterChatFinishes": true,
    "xmlTools.splitAttributesOnFormat": true,
    "workbench.tree.renderIndentGuides": "none",
    "workbench.tree.indent": 12,
    "markdown-preview-enhanced.previewTheme": "github-dark.css",
    "security.promptForLocalFileProtocolHandling": false,
    "window.newWindowProfile": "Default",
    "gitlens.blame.ignoreWhitespace": true,
    // --- Extension Tuning (ErrorLens & GitLens) ---
    "errorLens.messageBackgroundMode": "none",
    "errorLens.backgroundColor": "transparent",
    "errorLens.messageTemplate": " // $message",
    "errorLens.scrollbarHackEnabled": true,
    "errorLens.fontStyleItalic": true,
    "errorLens.gutterIconsEnabled": true,
    "gitlens.showWelcomeOnInstall": false,
    "gitlens.codeLens.enabled": false,
    "editor.accessibilitySupport": "off"
}